{
  "__comment__": "WHAT: A simple Grafana dashboard for the 'app' namespace. HOW TO IMPORT: Grafana UI → Dashboards → Import → Upload this JSON file.",
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "__comment__": "PANEL 1: Pod CPU Usage — Shows how much CPU each pod in the 'app' namespace is consuming. The query uses 'rate()' over 5 minutes to smooth out spiky data.",
      "title": "Pod CPU Usage (app namespace)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"app\", container!=\"\", container!=\"POD\"}[5m])) by (pod)",
          "legendFormat": "{{ pod }}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "__comment__": "PANEL 2: Pod Memory Usage — Shows working set memory (what the kernel counts toward limits). Displayed in MiB for readability.",
      "title": "Pod Memory Usage (app namespace)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"app\", container!=\"\", container!=\"POD\"}) by (pod)",
          "legendFormat": "{{ pod }}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "__comment__": "PANEL 3: Pod Restart Count — A bar gauge showing total restarts per pod. High numbers = something is crash-looping.",
      "title": "Pod Restart Count (app namespace)",
      "type": "bargauge",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"app\"}) by (pod)",
          "legendFormat": "{{ pod }}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "__comment__": "PANEL 4: Running Pods — A stat panel showing how many pods are currently in 'Running' phase. Quick health check at a glance.",
      "title": "Running Pods (app namespace)",
      "type": "stat",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"app\", phase=\"Running\"} == 1)",
          "legendFormat": "Running Pods",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["app", "kubernetes", "learning"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "App Namespace Overview",
  "uid": "app-namespace-overview",
  "version": 1
}
